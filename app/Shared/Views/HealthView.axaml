<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuailTracker.Shared.ViewModels"
             x:Class="QuailTracker.Shared.Views.HealthView"
             x:DataType="vm:HealthViewModel">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="16">

            <!-- Device / Battery / SD Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="6">
                    <!-- Device: Station ID + Firmware on one line -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="{Binding StationId}" FontSize="16" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding FirmwareVersion}"
                                   FontSize="12" Foreground="White" Opacity="0.6"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Battery: bar + percentage + voltage on one line -->
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <TextBlock Text="Bat" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" Width="28" />
                        <ProgressBar Grid.Column="1" Value="{Binding BatteryPercentage}" Maximum="100"
                                     Height="6" CornerRadius="3"
                                     Foreground="{Binding BatteryColor}"
                                     VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding BatteryPercentage, StringFormat={}{0}%}"
                                   Margin="8,0,0,0" FontSize="13" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="{Binding BatteryVoltage}"
                                   Margin="6,0,0,0" FontSize="11" Foreground="White"
                                   Opacity="0.5" VerticalAlignment="Center" />
                    </Grid>

                    <!-- SD Card: bar + percentage + free space on one line -->
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <TextBlock Text="SD" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" Width="28" />
                        <ProgressBar Grid.Column="1" Value="{Binding SdFreePercent}" Maximum="100"
                                     Height="6" CornerRadius="3"
                                     Foreground="{Binding SdColor}"
                                     VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding SdFreePercent, StringFormat={}{0}%}"
                                   Margin="8,0,0,0" FontSize="13" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="{Binding SdFree}"
                                   Margin="6,0,0,0" FontSize="11" Foreground="White"
                                   Opacity="0.5" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- GPS Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="GPS" Classes="SectionHeader" />
                        <Border Grid.Column="1" CornerRadius="4" Padding="8,4"
                                Background="{Binding GpsColor}">
                            <TextBlock Text="{Binding GpsStatus}" Foreground="White" FontSize="12" />
                        </Border>
                    </Grid>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                        <StackPanel>
                            <TextBlock Text="Satellites" Classes="DataLabel" />
                            <TextBlock Text="{Binding GpsSatellites}" FontSize="16" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="PPS" Classes="DataLabel" />
                            <TextBlock Text="{Binding PpsStatus}" FontSize="16" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                            <TextBlock Text="Position" Classes="DataLabel" />
                            <TextBlock Text="{Binding GpsPosition}" FontSize="14" Foreground="White" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="{Binding GpsTime}" Classes="DataLabel" />
                </StackPanel>
            </Border>

            <!-- Environment -->
            <Border Classes="CardPanel">
                <Grid ColumnDefinitions="Auto,*,Auto,8,Auto,*,Auto">
                    <TextBlock Text="Temp" FontSize="11" Foreground="White" Opacity="0.5"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding Temperature}"
                               FontSize="15" FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="4" Text="Hum" FontSize="11" Foreground="White" Opacity="0.5"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="6" Text="{Binding Humidity}"
                               FontSize="15" FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- BLE Connection -->
            <Border Classes="CardPanel">
                <Grid ColumnDefinitions="Auto,8,Auto,*,Auto">
                    <TextBlock Text="BLE" FontSize="11" Foreground="White" Opacity="0.5"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding BleStatus}"
                               FontSize="13" FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="4" Text="{Binding BleAddress}"
                               FontSize="11" Foreground="White" Opacity="0.5"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Refresh Button -->
            <Border Classes="CardPanel">
                <Grid ColumnDefinitions="*,Auto">
                    <Button Grid.Column="1"
                            Classes="ToolbarButton"
                            Command="{Binding RefreshCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                      Width="16" Height="16" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Last Updated -->
            <TextBlock Text="{Binding LastUpdated, StringFormat=Last updated: {0}}"
                       HorizontalAlignment="Center"
                       Classes="DataLabel" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
