<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuailTracker.Shared.ViewModels"
             x:Class="QuailTracker.Shared.Views.ConfigView"
             x:DataType="vm:ConfigViewModel">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="16">

            <!-- Station Identity -->
            <Border Background="#FFFFFF" CornerRadius="8" Padding="16"
                    BoxShadow="0 2 4 0 #20000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Station Identity" FontWeight="SemiBold" FontSize="14" Foreground="#666666" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="Station ID" FontSize="12" Foreground="#888888" />
                        <TextBox Text="{Binding StationId}"
                                 Watermark="e.g., QT001" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Audio Settings -->
            <Border Background="#FFFFFF" CornerRadius="8" Padding="16"
                    BoxShadow="0 2 4 0 #20000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Audio Settings" FontWeight="SemiBold" FontSize="14" Foreground="#666666" />

                    <StackPanel Spacing="4">
                        <TextBlock Text="Microphone Gain" FontSize="12" Foreground="#888888" />
                        <ComboBox ItemsSource="{Binding GainOptions}"
                                  SelectedIndex="{Binding SelectedGainIndex}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="High-Pass Filter" FontSize="12" Foreground="#888888" />
                        <ComboBox ItemsSource="{Binding HighPassOptions}"
                                  SelectedIndex="{Binding SelectedHighPassIndex}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Sample Rate" FontSize="12" Foreground="#888888" />
                        <ComboBox ItemsSource="{Binding SampleRateOptions}"
                                  SelectedIndex="{Binding SelectedSampleRateIndex}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Recording Schedule -->
            <Border Background="#FFFFFF" CornerRadius="8" Padding="16"
                    BoxShadow="0 2 4 0 #20000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Recording Schedule" FontWeight="SemiBold" FontSize="14" Foreground="#666666" />

                    <StackPanel Spacing="4">
                        <TextBlock Text="Schedule Mode" FontSize="12" Foreground="#888888" />
                        <ComboBox ItemsSource="{Binding ScheduleModeOptions}"
                                  SelectedIndex="{Binding SelectedScheduleModeIndex}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Sunrise/Sunset Options -->
                    <StackPanel Spacing="12"
                                IsVisible="{Binding SelectedScheduleModeIndex, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=1}">
                        <Grid ColumnDefinitions="*,12,*">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Before Sunrise (min)" FontSize="12" Foreground="#888888" />
                                <NumericUpDown Value="{Binding SunriseOffset}"
                                               Minimum="-120" Maximum="0"
                                               Increment="5" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="After Sunset (min)" FontSize="12" Foreground="#888888" />
                                <NumericUpDown Value="{Binding SunsetOffset}"
                                               Minimum="0" Maximum="120"
                                               Increment="5" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Manual Time Options -->
                    <StackPanel Spacing="12"
                                IsVisible="{Binding SelectedScheduleModeIndex, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}">
                        <Grid ColumnDefinitions="*,12,*">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Start Time" FontSize="12" Foreground="#888888" />
                                <TimePicker SelectedTime="{Binding ManualStartTime}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="End Time" FontSize="12" Foreground="#888888" />
                                <TimePicker SelectedTime="{Binding ManualEndTime}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Amplitude Triggering -->
            <Border Background="#FFFFFF" CornerRadius="8" Padding="16"
                    BoxShadow="0 2 4 0 #20000000">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Amplitude Trigger" FontWeight="SemiBold" FontSize="14" Foreground="#666666" />
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding AmplitudeTriggerEnabled}"
                                      OnContent="On" OffContent="Off" />
                    </Grid>

                    <StackPanel Spacing="12" IsEnabled="{Binding AmplitudeTriggerEnabled}">
                        <StackPanel Spacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Threshold" FontSize="12" Foreground="#888888" />
                                <TextBlock Grid.Column="1" Text="{Binding AmplitudeThreshold, StringFormat={}{0} dB}"
                                           FontSize="12" Foreground="#888888" />
                            </Grid>
                            <Slider Value="{Binding AmplitudeThreshold}"
                                    Minimum="-60" Maximum="-10"
                                    TickFrequency="5" IsSnapToTickEnabled="True" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,12,*">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Pre-trigger (sec)" FontSize="12" Foreground="#888888" />
                                <NumericUpDown Value="{Binding PreTriggerSeconds}"
                                               Minimum="0" Maximum="10"
                                               Increment="1" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Post-trigger (sec)" FontSize="12" Foreground="#888888" />
                                <NumericUpDown Value="{Binding PostTriggerSeconds}"
                                               Minimum="1" Maximum="30"
                                               Increment="1" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Power Management -->
            <Border Background="#FFFFFF" CornerRadius="8" Padding="16"
                    BoxShadow="0 2 4 0 #20000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Power Management" FontWeight="SemiBold" FontSize="14" Foreground="#666666" />

                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Low Battery Threshold" FontSize="12" Foreground="#888888" />
                            <TextBlock Grid.Column="1" Text="{Binding LowBatteryThreshold, StringFormat={}{0}%}"
                                       FontSize="12" Foreground="#888888" />
                        </Grid>
                        <Slider Value="{Binding LowBatteryThreshold}"
                                Minimum="5" Maximum="30"
                                TickFrequency="5" IsSnapToTickEnabled="True" />
                    </StackPanel>

                    <CheckBox IsChecked="{Binding AutoStopOnLowBattery}"
                              Content="Auto-stop recording on low battery" />
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Padding="16,12"
                        Command="{Binding ResetToDefaultsCommand}">
                    <TextBlock Text="Reset Defaults" HorizontalAlignment="Center" />
                </Button>
                <Button Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        Padding="16,12"
                        Command="{Binding SaveConfigCommand}"
                        IsEnabled="{Binding HasChanges}"
                        Background="{StaticResource QuailPrimaryBrush}">
                    <TextBlock Text="Save Config" Foreground="White" HorizontalAlignment="Center" />
                </Button>
            </Grid>

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}"
                       HorizontalAlignment="Center"
                       FontSize="12" Foreground="#888888"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <!-- Load Button -->
            <Button HorizontalAlignment="Stretch"
                    Padding="16,12"
                    Command="{Binding LoadConfigCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                    <PathIcon Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z"
                              Width="16" Height="16" />
                    <TextBlock Text="Load from Device" />
                </StackPanel>
            </Button>

        </StackPanel>
    </ScrollViewer>
</UserControl>
