<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuailTracker.Shared.ViewModels"
             x:Class="QuailTracker.Shared.Views.HealthView"
             x:DataType="vm:HealthViewModel">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="16">

            <!-- Device Info Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <TextBlock Text="Device" Classes="SectionHeader" />
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel>
                            <TextBlock Text="Station ID" Classes="DataLabel" />
                            <TextBlock Text="{Binding StationId}" FontSize="18" FontWeight="Bold" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Firmware" Classes="DataLabel" />
                            <TextBlock Text="{Binding FirmwareVersion}" FontSize="18" Foreground="White" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- BLE Connection Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <TextBlock Text="BLE Connection" Classes="SectionHeader" />
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel>
                            <TextBlock Text="Status" Classes="DataLabel" />
                            <TextBlock Text="{Binding BleStatus}" FontSize="16" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Device" Classes="DataLabel" />
                            <TextBlock Text="{Binding BleDeviceName}" FontSize="16" Foreground="White" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Battery Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Battery" Classes="SectionHeader" />
                        <Border Grid.Column="1" CornerRadius="4" Padding="8,4"
                                Background="{Binding BatteryColor}">
                            <TextBlock Text="{Binding BatteryStatus}" Foreground="White" FontSize="12" />
                        </Border>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <ProgressBar Value="{Binding BatteryPercentage}" Maximum="100"
                                     Height="8" CornerRadius="4"
                                     Foreground="{Binding BatteryColor}" />
                        <TextBlock Grid.Column="1" Text="{Binding BatteryPercentage, StringFormat={}{0}%}"
                                   Margin="8,0,0,0" FontWeight="Bold" Foreground="White" />
                    </Grid>
                    <TextBlock Text="{Binding BatteryVoltage}" Classes="DataLabel" />
                </StackPanel>
            </Border>

            <!-- GPS Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="GPS" Classes="SectionHeader" />
                        <Border Grid.Column="1" CornerRadius="4" Padding="8,4"
                                Background="{Binding GpsColor}">
                            <TextBlock Text="{Binding GpsStatus}" Foreground="White" FontSize="12" />
                        </Border>
                    </Grid>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                        <StackPanel>
                            <TextBlock Text="Satellites" Classes="DataLabel" />
                            <TextBlock Text="{Binding GpsSatellites}" FontSize="16" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="PPS" Classes="DataLabel" />
                            <TextBlock Text="{Binding PpsStatus}" FontSize="16" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                            <TextBlock Text="Position" Classes="DataLabel" />
                            <TextBlock Text="{Binding GpsPosition}" FontSize="14" Foreground="White" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="{Binding GpsTime}" Classes="DataLabel" />
                </StackPanel>
            </Border>

            <!-- Environment Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <TextBlock Text="Environment" Classes="SectionHeader" />
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel>
                            <TextBlock Text="Temperature" Classes="DataLabel" />
                            <TextBlock Text="{Binding Temperature}" Classes="LargeValue" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Humidity" Classes="DataLabel" />
                            <TextBlock Text="{Binding Humidity}" Classes="LargeValue" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- SD Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="SD Card" Classes="SectionHeader" />
                        <Border Grid.Column="1" CornerRadius="4" Padding="8,4"
                                Background="{Binding SdColor}">
                            <TextBlock Text="{Binding SdStatus}" Foreground="White" FontSize="12" />
                        </Border>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <ProgressBar Value="{Binding SdUsagePercent}" Maximum="100"
                                     Height="8" CornerRadius="4"
                                     Foreground="{Binding SdColor}" />
                        <TextBlock Grid.Column="1" Text="{Binding SdUsagePercent, StringFormat={}{0}%}"
                                   Margin="8,0,0,0" Foreground="White" />
                    </Grid>
                    <TextBlock Text="{Binding SdUsage}" Classes="DataLabel" />
                </StackPanel>
            </Border>

            <!-- Refresh Button -->
            <Button HorizontalAlignment="Stretch"
                    Classes="ToolbarButton"
                    Command="{Binding RefreshCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                    <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                              Width="16" Height="16" />
                    <TextBlock Text="Refresh Status" />
                </StackPanel>
            </Button>

            <!-- Last Updated -->
            <TextBlock Text="{Binding LastUpdated, StringFormat=Last updated: {0}}"
                       HorizontalAlignment="Center"
                       Classes="DataLabel" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
