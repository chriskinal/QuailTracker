<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuailTracker.Shared.ViewModels"
             x:Class="QuailTracker.Shared.Views.ConfigView"
             x:DataType="vm:ConfigViewModel">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="12">

            <!-- Station + Audio -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <!-- Station ID -->
                    <Grid ColumnDefinitions="Auto,8,*">
                        <TextBlock Text="Station" FontSize="13" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                        <TextBox Grid.Column="2" Text="{Binding StationId}"
                                 Watermark="e.g., QT001" />
                    </Grid>

                    <!-- Gain + Format + Sample Rate on one row -->
                    <Grid ColumnDefinitions="*,8,*,8,*">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Gain" FontSize="11" Foreground="White" Opacity="0.5" />
                            <ComboBox ItemsSource="{Binding GainOptions}"
                                      SelectedIndex="{Binding SelectedGainIndex}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="2">
                            <TextBlock Text="Format" FontSize="11" Foreground="White" Opacity="0.5" />
                            <ComboBox ItemsSource="{Binding FormatOptions}"
                                      SelectedIndex="{Binding SelectedFormatIndex}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel Grid.Column="4" Spacing="2">
                            <TextBlock Text="Rate" FontSize="11" Foreground="White" Opacity="0.5" />
                            <ComboBox ItemsSource="{Binding SampleRateOptions}"
                                      SelectedIndex="{Binding SelectedSampleRateIndex}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Grid>

                    <!-- HPF slider -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="HPF" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" Width="30" />
                        <Slider Grid.Column="1" Value="{Binding BandPassLowHz}"
                                Minimum="0" Maximum="1500"
                                TickFrequency="10" IsSnapToTickEnabled="True" />
                        <TextBlock Grid.Column="2" Text="{Binding BandPassLowHz, StringFormat={}{0} Hz}"
                                   FontSize="11" Foreground="White" Opacity="0.6"
                                   VerticalAlignment="Center" Width="55" TextAlignment="Right" />
                    </Grid>

                    <!-- LPF slider -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="LPF" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" Width="30" />
                        <Slider Grid.Column="1" Value="{Binding BandPassHighHz}"
                                Minimum="1000" Maximum="24000"
                                TickFrequency="500" IsSnapToTickEnabled="True" />
                        <TextBlock Grid.Column="2" Text="{Binding BandPassHighHz, StringFormat={}{0} Hz}"
                                   FontSize="11" Foreground="White" Opacity="0.6"
                                   VerticalAlignment="Center" Width="55" TextAlignment="Right" />
                    </Grid>

                    <!-- Chunk duration slider -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="Chunk" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" Width="30" />
                        <Slider Grid.Column="1" Minimum="0" Maximum="120"
                                Value="{Binding ChunkMinutes}"
                                TickFrequency="15" IsSnapToTickEnabled="True" />
                        <TextBlock Grid.Column="2" Text="{Binding ChunkMinutesLabel}"
                                   FontSize="11" Foreground="White" Opacity="0.6"
                                   VerticalAlignment="Center" Width="55" TextAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Amplitude Trigger -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Amplitude Trigger" FontSize="13" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding AmplitudeTriggerEnabled}"
                                      OnContent="On" OffContent="Off" />
                    </Grid>

                    <!-- Live Audio toggle + level -->
                    <Grid ColumnDefinitions="Auto,8,*,Auto">
                        <TextBlock Text="Live" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <ProgressBar Grid.Column="2" Value="{Binding AudioLevel}" Maximum="100"
                                     Height="8" CornerRadius="4" Foreground="#4CAF50"
                                     VerticalAlignment="Center"
                                     IsVisible="{Binding AudioStreamEnabled}" />
                        <ToggleSwitch Grid.Column="3"
                                      IsChecked="{Binding AudioStreamEnabled}"
                                      IsEnabled="{Binding AmplitudeTriggerEnabled}"
                                      OnContent="On" OffContent="Off" />
                    </Grid>

                    <StackPanel Spacing="6" IsEnabled="{Binding AmplitudeTriggerEnabled}">
                        <!-- Threshold slider -->
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Text="Thr" FontSize="11" Foreground="White" Opacity="0.5"
                                       VerticalAlignment="Center" Width="30" />
                            <Slider Grid.Column="1" Value="{Binding AmplitudeThreshold}"
                                    Minimum="-60" Maximum="-10"
                                    TickFrequency="5" IsSnapToTickEnabled="True" />
                            <TextBlock Grid.Column="2" Text="{Binding AmplitudeThreshold, StringFormat={}{0} dB}"
                                       FontSize="11" Foreground="White" Opacity="0.6"
                                       VerticalAlignment="Center" Width="45" TextAlignment="Right" />
                        </Grid>

                        <!-- Pre/Post trigger on one row -->
                        <Grid ColumnDefinitions="Auto,8,Auto,*,Auto,8,Auto">
                            <TextBlock Text="Pre" FontSize="11" Foreground="White" Opacity="0.5"
                                       VerticalAlignment="Center" />
                            <NumericUpDown Grid.Column="2" Value="{Binding PreTriggerSeconds}"
                                           Minimum="0" Maximum="10" Increment="1" Width="80" />
                            <TextBlock Grid.Column="4" Text="Post" FontSize="11" Foreground="White" Opacity="0.5"
                                       VerticalAlignment="Center" />
                            <NumericUpDown Grid.Column="6" Value="{Binding PostTriggerSeconds}"
                                           Minimum="1" Maximum="30" Increment="1" Width="80" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Power -->
            <Border Classes="CardPanel">
                <Grid ColumnDefinitions="Auto,*,Auto,8,Auto">
                    <TextBlock Text="Low Bat" FontSize="11" Foreground="White" Opacity="0.5"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="1" Value="{Binding LowBatteryThreshold}"
                            Minimum="5" Maximum="30"
                            TickFrequency="5" IsSnapToTickEnabled="True"
                            Margin="8,0" />
                    <TextBlock Grid.Column="2" Text="{Binding LowBatteryThreshold, StringFormat={}{0}%}"
                               FontSize="12" Foreground="White"
                               VerticalAlignment="Center" />
                    <CheckBox Grid.Column="4" IsChecked="{Binding AutoStopOnLowBattery}"
                              Content="Auto-stop" Foreground="White" FontSize="12"
                              VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Save / Reset / Load -->
            <Grid ColumnDefinitions="*,8,*">
                <Button Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Classes="ToolbarButton"
                        Command="{Binding ResetToDefaultsCommand}">
                    <TextBlock Text="Reset Defaults" FontSize="13" />
                </Button>
                <Button Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Classes="PrimaryButton"
                        Command="{Binding SaveConfigCommand}"
                        IsEnabled="{Binding HasChanges}">
                    <TextBlock Text="Save Config" FontSize="13" />
                </Button>
            </Grid>

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}"
                       HorizontalAlignment="Center" FontSize="11"
                       Classes="DataLabel"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <!-- Load + Apply & Next -->
            <Grid ColumnDefinitions="*,8,*">
                <Button Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Classes="ToolbarButton"
                        Command="{Binding LoadConfigCommand}">
                    <TextBlock Text="Load from Device" FontSize="13" />
                </Button>
                <Button Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Classes="ToolbarButton"
                        Command="{Binding ApplyAndNextCommand}">
                    <TextBlock Text="Apply &amp; Next" FontSize="13" />
                </Button>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
