<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuailTracker.Shared.ViewModels"
             x:Class="QuailTracker.Shared.Views.OperationsView"
             x:DataType="vm:OperationsViewModel">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="16">

            <!-- Recording Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Recording" Classes="SectionHeader" />
                        <Border Grid.Column="1" CornerRadius="4" Padding="8,4"
                                Background="{Binding RecordingColor}">
                            <TextBlock Text="{Binding RecordingStatus}" Foreground="White" FontSize="12" />
                        </Border>
                    </Grid>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                        <StackPanel>
                            <TextBlock Text="File" Classes="DataLabel" />
                            <TextBlock Text="{Binding CurrentFile}" FontSize="14" TextTrimming="CharacterEllipsis" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Size" Classes="DataLabel" />
                            <TextBlock Text="{Binding FileSize}" FontSize="14" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Margin="0,8,0,0">
                            <TextBlock Text="Buffer" Classes="DataLabel" />
                            <TextBlock Text="{Binding BufferStatus}" FontSize="14" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,8,0,0">
                            <TextBlock Text="Overflows" Classes="DataLabel" />
                            <TextBlock Text="{Binding Overflows}" FontSize="14" Foreground="White" />
                        </StackPanel>
                    </Grid>

                    <!-- Record Button -->
                    <Button HorizontalAlignment="Stretch"
                            Margin="0,8,0,0"
                            Padding="16,12"
                            Command="{Binding ToggleRecordingCommand}"
                            Background="{Binding RecordingColor}">
                        <TextBlock Text="{Binding RecordButtonText}"
                                   Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Border>

            <!-- SD Card Actions Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="SD Card" Classes="SectionHeader" />
                        <Border Grid.Column="1" CornerRadius="4" Padding="8,4"
                                Background="{Binding SdColor}">
                            <TextBlock Text="{Binding SdStatus}" Foreground="White" FontSize="12" />
                        </Border>
                    </Grid>
                    <Grid ColumnDefinitions="*,8,*,8,*">
                        <Button Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Classes="ToolbarButton"
                                Command="{Binding MountSdCommand}">
                            <TextBlock Text="Mount" HorizontalAlignment="Center" />
                        </Button>
                        <Button Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                Classes="ToolbarButton"
                                Command="{Binding EjectSdCommand}">
                            <TextBlock Text="Eject" HorizontalAlignment="Center" />
                        </Button>
                        <Button Grid.Column="4"
                                HorizontalAlignment="Stretch"
                                Classes="DangerButton"
                                Command="{Binding FormatSdCommand}">
                            <TextBlock Text="Format" HorizontalAlignment="Center" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- GPS Detail Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="GPS" Classes="SectionHeader" />
                        <Border Grid.Column="1" CornerRadius="4" Padding="8,4"
                                Background="{Binding GpsColor}">
                            <TextBlock Text="{Binding GpsFixType}" Foreground="White" FontSize="12" />
                        </Border>
                    </Grid>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                        <StackPanel>
                            <TextBlock Text="Satellites" Classes="DataLabel" />
                            <TextBlock Text="{Binding GpsSatellites}" FontSize="16" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Date" Classes="DataLabel" />
                            <TextBlock Text="{Binding GpsDate}" FontSize="16" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                            <TextBlock Text="Position" Classes="DataLabel" />
                            <TextBlock Text="{Binding GpsPosition}" FontSize="14" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Margin="0,8,0,0">
                            <TextBlock Text="UTC Time" Classes="DataLabel" />
                            <TextBlock Text="{Binding GpsTime}" FontSize="14" Foreground="White" />
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,*,*">
                        <StackPanel>
                            <TextBlock Text="PPS" Classes="DataLabel" />
                            <TextBlock Text="{Binding PpsStatus}" FontSize="14" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="PPS Count" Classes="DataLabel" />
                            <TextBlock Text="{Binding PpsCount}" FontSize="14" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="PPS Age" Classes="DataLabel" />
                            <TextBlock Text="{Binding PpsAge}" FontSize="14" Foreground="White" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Location Survey Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Location Survey" Classes="SectionHeader" />
                        <Border Grid.Column="1" CornerRadius="4" Padding="8,4"
                                Background="{Binding SurveyColor}">
                            <TextBlock Foreground="White" FontSize="12">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} fixes">
                                        <Binding Path="SurveyCount" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Border>
                    </Grid>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.ColumnSpan="2">
                            <TextBlock Text="Surveyed Position" Classes="DataLabel" />
                            <TextBlock Text="{Binding SurveyPosition}" FontSize="14" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Margin="0,8,0,0">
                            <TextBlock Text="Altitude" Classes="DataLabel" />
                            <TextBlock Text="{Binding SurveyAltitude}" FontSize="14" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,8,0,0">
                            <TextBlock Text="Fix Count" Classes="DataLabel" />
                            <TextBlock Text="{Binding SurveyCount}" FontSize="14" Foreground="White" />
                        </StackPanel>
                    </Grid>

                    <!-- Warning when not enough satellites -->
                    <TextBlock Text="Need 4+ satellites to survey"
                               FontSize="12" Foreground="#FFC107"
                               IsVisible="{Binding !CanStartSurvey}" />

                    <!-- Survey Buttons -->
                    <Grid ColumnDefinitions="*,8,*">
                        <Button Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Classes="ToolbarButton"
                                Command="{Binding ToggleSurveyCommand}">
                            <TextBlock Text="{Binding SurveyButtonText}"
                                       HorizontalAlignment="Center" />
                        </Button>
                        <Button Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                Classes="DangerButton"
                                Command="{Binding ClearSurveyCommand}">
                            <TextBlock Text="Clear" HorizontalAlignment="Center" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- BLE Module Detail Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="BLE Module" Classes="SectionHeader" />
                        <Border Grid.Column="1" CornerRadius="4" Padding="8,4"
                                Background="{Binding BleColor}">
                            <TextBlock Text="{Binding BleModule}" Foreground="White" FontSize="12" />
                        </Border>
                    </Grid>
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel>
                            <TextBlock Text="Name" Classes="DataLabel" />
                            <TextBlock Text="{Binding BleName}" FontSize="14" Foreground="White" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Link" Classes="DataLabel" />
                            <TextBlock Text="{Binding BleLink}" FontSize="14" Foreground="White" />
                        </StackPanel>
                    </Grid>
                    <StackPanel>
                        <TextBlock Text="Address" Classes="DataLabel" />
                        <TextBlock Text="{Binding BleAddr}" FontSize="14" Foreground="White" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Refresh Button -->
            <Button Classes="ToolbarButton"
                    HorizontalAlignment="Stretch"
                    Command="{Binding RefreshCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                    <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                              Width="16" Height="16" />
                    <TextBlock Text="Refresh" />
                </StackPanel>
            </Button>

        </StackPanel>
    </ScrollViewer>
</UserControl>
