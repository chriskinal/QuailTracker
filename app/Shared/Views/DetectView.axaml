<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QuailTracker.Shared.ViewModels"
        x:Class="QuailTracker.Shared.Views.DetectView"
        x:DataType="vm:DetectViewModel">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="12">

            <!-- Model Status -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <TextBlock Text="Model Status" Classes="SectionHeader" />
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding ModelInfo}" FontSize="14" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding ModelColor}" />
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="{Binding DetectionStatus}"
                                           FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Reload"
                                Command="{Binding ReloadModelCommand}"
                                Classes="SecondaryButton" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Detection Control -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="12">
                    <TextBlock Text="Detection Control" Classes="SectionHeader" />

                    <!-- Mission Mode -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Mission Mode" FontSize="12" Opacity="0.7" />
                        <ComboBox ItemsSource="{Binding MissionOptions}"
                                  SelectedIndex="{Binding SelectedMissionIndex}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Confidence Threshold -->
                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Confidence Threshold" FontSize="12" Opacity="0.7" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DetectionThreshold, StringFormat='{}{0}%'}"
                                       FontSize="12" FontWeight="SemiBold" />
                        </Grid>
                        <Slider Minimum="10" Maximum="100"
                                Value="{Binding DetectionThreshold}"
                                TickFrequency="5" IsSnapToTickEnabled="True" />
                    </StackPanel>

                    <!-- Window Step -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Window Step" FontSize="12" Opacity="0.7" />
                        <ComboBox ItemsSource="{Binding WindowStepOptions}"
                                  SelectedIndex="{Binding SelectedWindowStepIndex}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Save Button -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="12" Opacity="0.7"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="Save"
                                Command="{Binding SaveCommand}"
                                IsEnabled="{Binding HasChanges}"
                                Classes="PrimaryButton" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Detection Stats -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <TextBlock Text="Detection Stats" Classes="SectionHeader" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                            <TextBlock Text="Windows" FontSize="11" Opacity="0.5" />
                            <TextBlock Text="{Binding WindowsProcessed}"
                                       FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                            <TextBlock Text="Hits" FontSize="11" Opacity="0.5" />
                            <TextBlock Text="{Binding DetectionHits}"
                                       FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Last Detection -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <TextBlock Text="Last Detection" Classes="SectionHeader" />

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding LastSpecies}"
                                       FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding LastTime}"
                                       FontSize="12" Opacity="0.5" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastConfidence}"
                                   FontSize="24" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Live Stream -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Live Detections" Classes="SectionHeader" />
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding StreamEnabled}"
                                      OnContent="On" OffContent="Off" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding DetectionLog}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="12"
                                           FontFamily="Cascadia Mono, Consolas, monospace"
                                           Margin="0,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Refresh -->
            <Button HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Command="{Binding RefreshCommand}"
                    Classes="ToolbarButton">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                              Width="14" Height="14" />
                    <TextBlock Text="Refresh" FontSize="13" />
                </StackPanel>
            </Button>

        </StackPanel>
    </ScrollViewer>

</UserControl>
