<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svg="using:Avalonia.Svg.Skia"
        xmlns:vm="using:QuailTracker.Analyzer.Shared.ViewModels"
        xmlns:views="using:QuailTracker.Analyzer.Shared.Views"
        x:Class="QuailTracker.Analyzer.Shared.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="QuailTracker Analyzer"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource QuailPrimaryBrush}"
                Padding="16,12">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <svg:Svg Grid.Column="0"
                        Path="avares://QuailTracker.Analyzer.Shared/Assets/logo.svg"
                        Width="45" Height="45"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="QuailTracker Analyzer"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Text="Bird Detection &amp; TDOA Localization"
                               FontSize="12"
                               Foreground="White"
                               Opacity="0.8" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Top-level tabs -->
        <TabControl Grid.Row="1" Margin="8">

            <!-- Single Analysis -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M3,9H7V5H3V9M3,14H7V10H3V14M8,14H12V10H8V14M13,14H17V10H13V14M8,9H12V5H8V9M13,5V9H17V5H13M18,14H22V10H18V14M3,19H7V15H3V19M8,19H12V15H8V19M13,19H17V15H13V19M18,19H22V15H18V19M18,5V9H22V5H18Z"
                                  Width="16" Height="16" />
                        <TextBlock Text="Single Analysis" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <views:SingleAnalysisView DataContext="{Binding SingleAnalysisViewModel}" />
            </TabItem>

            <!-- Bulk Analysis -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z"
                                  Width="16" Height="16" />
                        <TextBlock Text="Bulk Analysis" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <TabControl Margin="0,4,0,0">
                    <TabItem Header="Import">
                        <views:ImportView DataContext="{Binding ImportViewModel}" />
                    </TabItem>
                    <TabItem Header="Processing">
                        <views:ProcessingView DataContext="{Binding ProcessingViewModel}" />
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- Analytics &amp; Visualization -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M22,21H2V3H4V19H6V10H10V19H12V14H16V19H18V12H22V21Z"
                                  Width="16" Height="16" />
                        <TextBlock Text="Analytics &amp; Visualization" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <TabControl Margin="0,4,0,0">
                    <TabItem Header="Localization">
                        <views:LocalizationView DataContext="{Binding LocalizationViewModel}" />
                    </TabItem>
                    <TabItem Header="Population">
                        <views:PopulationView DataContext="{Binding PopulationViewModel}" />
                    </TabItem>
                    <TabItem Header="Mapping">
                        <views:MapView DataContext="{Binding MapViewModel}" />
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- Modeling -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="M3,17V19H9V17H3M3,5V7H13V5H3M13,21V19H21V17H13V15H11V21H13M7,9V11H3V13H7V15H9V9H7M21,13V11H11V13H21M15,9H17V7H21V5H17V3H15V9Z"
                                  Width="16" Height="16" />
                        <TextBlock Text="Modeling" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>
                <TabControl Margin="0,4,0,0">
                    <TabItem Header="Data">
                        <Grid RowDefinitions="Auto,*">
                            <views:XenoCantoDownloadView Grid.Row="0"
                                                         DataContext="{Binding XenoCantoDownloadViewModel}"
                                                         Margin="8,8,8,0" />
                            <views:TrainingDataView Grid.Row="1"
                                                    DataContext="{Binding TrainingDataViewModel}" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Training">
                        <views:ModelingTrainingView DataContext="{Binding ModelingTrainingViewModel}" />
                    </TabItem>
                    <TabItem Header="Evaluation">
                        <Border Padding="32" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel Spacing="12" MaxWidth="540" HorizontalAlignment="Center">
                                <PathIcon Data="M22,21H2V3H4V19H6V10H10V19H12V14H16V19H18V12H22V21Z"
                                          Width="48" Height="48"
                                          Foreground="#BDBDBD"
                                          HorizontalAlignment="Center" />
                                <TextBlock Text="Native evaluation UI — coming soon"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Foreground="#757575" />
                                <TextBlock Text="Will host: training/validation loss and accuracy curves, AUC and confusion matrix per class, and download buttons for trained model artifacts (.tflite, .onnx). Backed by the container's /api/outputs and /api/outputs/&lt;file&gt; endpoints."
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Foreground="#9E9E9E"
                                           FontSize="13" />
                                <TextBlock Text="Until then, training artifacts are written to training/output/ on disk. The Flask UI at http://localhost:5050 also lists them."
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Foreground="#9E9E9E"
                                           FontSize="12"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </TabItem>
                </TabControl>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
