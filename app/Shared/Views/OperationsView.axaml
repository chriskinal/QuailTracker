<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuailTracker.Shared.ViewModels"
             x:Class="QuailTracker.Shared.Views.OperationsView"
             x:DataType="vm:OperationsViewModel">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="16">

            <!-- Recording Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="5">
                    <!-- Line 1: Recording label + filename -->
                    <Grid ColumnDefinitions="Auto,8,*">
                        <TextBlock Text="Rec" FontSize="13" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding CurrentFile}"
                                   FontSize="12" Foreground="White" Opacity="0.7"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Line 2: Size / Buffer / Overflows / Clips -->
                    <Grid ColumnDefinitions="Auto,6,Auto,*,Auto,6,Auto,*,Auto,6,Auto,*,Auto,6,Auto">
                        <TextBlock Text="Size" FontSize="10" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding FileSize}"
                                   FontSize="12" FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="4" Text="Buf" FontSize="10" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="6" Text="{Binding BufferStatus}"
                                   FontSize="12" FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="8" Text="Ovf" FontSize="10" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="10" Text="{Binding Overflows}"
                                   FontSize="12" FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="12" Text="Clip" FontSize="10" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="14" Text="{Binding LimiterClips}"
                                   FontSize="12" FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Record Button -->
                    <Button HorizontalAlignment="Stretch"
                            Margin="0,4,0,0"
                            Padding="12,10"
                            Command="{Binding ToggleRecordingCommand}"
                            Background="{Binding RecordingColor}">
                        <TextBlock Text="{Binding RecordButtonText}"
                                   Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" HorizontalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Border>

            <!-- SD Card Actions Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="SD Card" Classes="SectionHeader" />
                        <Border Grid.Column="1" CornerRadius="4" Padding="8,4"
                                Background="{Binding SdColor}">
                            <TextBlock Text="{Binding SdStatus}" Foreground="White" FontSize="12" />
                        </Border>
                    </Grid>
                    <Grid ColumnDefinitions="*,8,*,8,*">
                        <Button Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Classes="ToolbarButton"
                                Command="{Binding MountSdCommand}">
                            <TextBlock Text="Mount" HorizontalAlignment="Center" />
                        </Button>
                        <Button Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                Classes="ToolbarButton"
                                Command="{Binding EjectSdCommand}">
                            <TextBlock Text="Eject" HorizontalAlignment="Center" />
                        </Button>
                        <Button Grid.Column="4"
                                HorizontalAlignment="Stretch"
                                Padding="16,12"
                                CornerRadius="6"
                                BorderThickness="0"
                                Background="{Binding FormatButtonColor}"
                                Command="{Binding FormatSdCommand}">
                            <TextBlock Text="{Binding FormatButtonText}"
                                       Foreground="White" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Location Survey (includes GPS position) -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="5">
                    <!-- Line 1: Survey header + badge -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Location Survey" FontSize="13" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                        <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                Background="{Binding SurveyColor}">
                            <TextBlock Text="{Binding SurveyBadge}" Foreground="White" FontSize="11" />
                        </Border>
                    </Grid>

                    <!-- Line 2: Current GPS position + time -->
                    <Grid ColumnDefinitions="Auto,6,*,Auto">
                        <TextBlock Text="Current" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding GpsPosition}" FontSize="12"
                                   Foreground="White" Opacity="0.7" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="{Binding GpsTime}"
                                   FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Line 3: Surveyed position + alt + fixes -->
                    <Grid ColumnDefinitions="Auto,6,*,Auto,6,Auto">
                        <TextBlock Text="Survey" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding SurveyPosition}" FontSize="12"
                                   FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="{Binding SurveyAltitude}"
                                   FontSize="11" Foreground="White" Opacity="0.6"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="5" Text="{Binding SurveyCount}"
                                   FontSize="11" Foreground="White" Opacity="0.6"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Warning -->
                    <TextBlock Text="Need 4+ satellites to survey"
                               FontSize="11" Foreground="#FFC107"
                               IsVisible="{Binding !CanStartSurvey}" />

                    <!-- Survey Buttons -->
                    <Grid ColumnDefinitions="*,8,*">
                        <Button Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Padding="12,10"
                                CornerRadius="6"
                                BorderThickness="0"
                                Background="{Binding SurveyButtonColor}"
                                Command="{Binding ToggleSurveyCommand}">
                            <TextBlock Text="{Binding SurveyButtonText}"
                                       Foreground="White" FontWeight="SemiBold"
                                       FontSize="13" HorizontalAlignment="Center" />
                        </Button>
                        <Button Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                Classes="DangerButton"
                                Command="{Binding ClearSurveyCommand}">
                            <TextBlock Text="Clear" FontSize="13" HorizontalAlignment="Center" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>


            <!-- Refresh -->
            <Grid ColumnDefinitions="*,Auto">
                <Button Classes="ToolbarButton"
                        HorizontalAlignment="Stretch"
                        Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                  Width="16" Height="16" />
                        <TextBlock Text="Refresh" />
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="1"
                           Text="{Binding LastRefreshed}"
                           FontSize="12" Opacity="0.5"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
