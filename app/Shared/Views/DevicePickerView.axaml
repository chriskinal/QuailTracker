<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuailTracker.Shared.ViewModels"
             x:Class="QuailTracker.Shared.Views.DevicePickerView"
             x:DataType="vm:DevicePickerViewModel">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Select a Device"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,12" />

        <!-- Device List -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Devices}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DiscoveredDeviceItem">
                        <Button Command="{Binding $parent[ItemsControl].((vm:DevicePickerViewModel)DataContext).SelectDeviceCommand}"
                                CommandParameter="{Binding}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Margin="0,0,0,8"
                                Cursor="Hand">
                            <Border Classes="CardPanel" Padding="12">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <!-- Signal indicator -->
                                    <Ellipse Grid.Column="0"
                                             Width="12" Height="12"
                                             VerticalAlignment="Center"
                                             Margin="0,0,12,0">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding SignalColor}" />
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <!-- Device name -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               Opacity="{Binding NameOpacity}" />

                                    <!-- RSSI -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding RssiText}"
                                               FontSize="12"
                                               Foreground="#888888"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Bottom: Status + Buttons -->
        <StackPanel Grid.Row="2" Spacing="12" Margin="0,12,0,0">
            <TextBlock Text="{Binding ScanStatus}"
                       HorizontalAlignment="Center"
                       Classes="DataLabel" />

            <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Classes="ToolbarButton"
                        Command="{Binding CancelCommand}">
                    <TextBlock Text="Cancel" HorizontalAlignment="Center" />
                </Button>
                <Button Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        Classes="PrimaryButton"
                        Command="{Binding ScanCommand}">
                    <TextBlock Text="{Binding ScanButtonText}" HorizontalAlignment="Center" />
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
