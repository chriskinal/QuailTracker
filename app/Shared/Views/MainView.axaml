<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QuailTracker.Shared.ViewModels"
        xmlns:views="using:QuailTracker.Shared.Views"
        x:Class="QuailTracker.Shared.Views.MainView"
        x:DataType="vm:MainWindowViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource QuailPrimaryBrush}"
                Padding="16">
            <StackPanel>
                <TextBlock Text="QuailTracker"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White" />
                <TextBlock Text="{Binding ConnectionStatus}"
                           FontSize="12"
                           Foreground="White"
                           Opacity="0.8" />
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <TabControl Grid.Row="1"
                    TabStripPlacement="Bottom"
                    SelectedIndex="{Binding SelectedTabIndex}">

            <!-- Health Tab -->
            <TabItem Header="Health">
                <TabItem.HeaderTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="4">
                            <PathIcon Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z"
                                      Width="20" Height="20" />
                            <TextBlock Text="Health" HorizontalAlignment="Center" FontSize="10" />
                        </StackPanel>
                    </DataTemplate>
                </TabItem.HeaderTemplate>
                <views:HealthView DataContext="{Binding HealthViewModel}" />
            </TabItem>

            <!-- Configuration Tab -->
            <TabItem Header="Config">
                <TabItem.HeaderTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="4">
                            <PathIcon Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                      Width="20" Height="20" />
                            <TextBlock Text="Config" HorizontalAlignment="Center" FontSize="10" />
                        </StackPanel>
                    </DataTemplate>
                </TabItem.HeaderTemplate>
                <views:ConfigView DataContext="{Binding ConfigViewModel}" />
            </TabItem>
        </TabControl>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="2"
                Background="#F5F5F5"
                Padding="8"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding DeviceName}"
                           VerticalAlignment="Center"
                           FontSize="12" />
                <Button Grid.Column="1"
                        Content="{Binding ConnectButtonText}"
                        Command="{Binding ConnectCommand}"
                        Padding="16,8" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
