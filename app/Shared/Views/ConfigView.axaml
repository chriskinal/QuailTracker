<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuailTracker.Shared.ViewModels"
             x:Class="QuailTracker.Shared.Views.ConfigView"
             x:DataType="vm:ConfigViewModel">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="16">

            <!-- Station Identity -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="12">
                    <TextBlock Text="Station Identity" Classes="SectionHeader" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="Station ID" Classes="DataLabel" />
                        <TextBox Text="{Binding StationId}"
                                 Watermark="e.g., QT001" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Audio Settings -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="12">
                    <TextBlock Text="Audio Settings" Classes="SectionHeader" />

                    <StackPanel Spacing="4">
                        <TextBlock Text="Microphone Gain" Classes="DataLabel" />
                        <ComboBox ItemsSource="{Binding GainOptions}"
                                  SelectedIndex="{Binding SelectedGainIndex}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Low Cutoff (HPF)" Classes="DataLabel" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding BandPassLowHz, StringFormat={}{0} Hz}"
                                       Classes="DataLabel" />
                        </Grid>
                        <Slider Value="{Binding BandPassLowHz}"
                                Minimum="0" Maximum="1500"
                                TickFrequency="10" IsSnapToTickEnabled="True" />
                        <TextBlock Text="0 = disabled" Classes="DataLabel"
                                   FontSize="11" Opacity="0.6" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="High Cutoff (LPF)" Classes="DataLabel" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding BandPassHighHz, StringFormat={}{0} Hz}"
                                       Classes="DataLabel" />
                        </Grid>
                        <Slider Value="{Binding BandPassHighHz}"
                                Minimum="1000" Maximum="24000"
                                TickFrequency="500" IsSnapToTickEnabled="True" />
                        <TextBlock Text="0 = disabled" Classes="DataLabel"
                                   FontSize="11" Opacity="0.6" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,12,*">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Sample Rate" Classes="DataLabel" />
                            <ComboBox ItemsSource="{Binding SampleRateOptions}"
                                      SelectedIndex="{Binding SelectedSampleRateIndex}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Format" Classes="DataLabel" />
                            <ComboBox ItemsSource="{Binding FormatOptions}"
                                      SelectedIndex="{Binding SelectedFormatIndex}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Activity Filter -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="12">
                    <TextBlock Text="Activity Filter" Classes="SectionHeader" />

                    <StackPanel Spacing="4">
                        <TextBlock Text="Mode" Classes="DataLabel" />
                        <ComboBox ItemsSource="{Binding ActivityModeOptions}"
                                  SelectedIndex="{Binding SelectedActivityModeIndex}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Live activity ratio (visible when mode > Off) -->
                    <StackPanel Spacing="4"
                                IsVisible="{Binding IsActivityFilterEnabled}">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Activity Ratio" Classes="DataLabel" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ActivityRatio, StringFormat={}{0}%}"
                                       Classes="DataLabel" />
                        </Grid>
                        <ProgressBar Value="{Binding ActivityRatio}" Maximum="100"
                                     Height="16" CornerRadius="4"
                                     Foreground="#FF9800" />
                    </StackPanel>

                    <StackPanel Spacing="12"
                                IsEnabled="{Binding IsActivityFilterEnabled}">
                        <StackPanel Spacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Min Activity %" Classes="DataLabel" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ActivityMinPercent, StringFormat={}{0}%}"
                                           Classes="DataLabel" />
                            </Grid>
                            <Slider Value="{Binding ActivityMinPercent}"
                                    Minimum="1" Maximum="50"
                                    TickFrequency="1" IsSnapToTickEnabled="True" />
                            <TextBlock Text="Below = silence, skip" Classes="DataLabel"
                                       FontSize="11" Opacity="0.6" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Max Activity %" Classes="DataLabel" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ActivityMaxPercent, StringFormat={}{0}%}"
                                           Classes="DataLabel" />
                            </Grid>
                            <Slider Value="{Binding ActivityMaxPercent}"
                                    Minimum="50" Maximum="99"
                                    TickFrequency="1" IsSnapToTickEnabled="True" />
                            <TextBlock Text="Above = broadband noise, skip" Classes="DataLabel"
                                       FontSize="11" Opacity="0.6" />
                        </StackPanel>

                        <StackPanel Spacing="4"
                                    IsVisible="{Binding IsGateMode}">
                            <TextBlock Text="Hold Time (sec)" Classes="DataLabel" />
                            <NumericUpDown Value="{Binding ActivityHoldSeconds}"
                                           Minimum="1" Maximum="30"
                                           Increment="1" />
                            <TextBlock Text="Delay before stopping in gate mode" Classes="DataLabel"
                                       FontSize="11" Opacity="0.6" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Amplitude Triggering -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Amplitude Trigger" Classes="SectionHeader" />
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding AmplitudeTriggerEnabled}"
                                      OnContent="On" OffContent="Off" />
                    </Grid>

                    <!-- Live Audio Stream Toggle -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Live Audio" Classes="DataLabel"
                                   VerticalAlignment="Center" />
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding AudioStreamEnabled}"
                                      IsEnabled="{Binding AmplitudeTriggerEnabled}"
                                      OnContent="On" OffContent="Off" />
                    </Grid>

                    <!-- Live Audio Level -->
                    <StackPanel Spacing="4"
                                IsVisible="{Binding AudioStreamEnabled}">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Audio Level" Classes="DataLabel" />
                            <TextBlock Grid.Column="1" Text="{Binding PeakLevel}" Classes="DataLabel" />
                        </Grid>
                        <ProgressBar Value="{Binding AudioLevel}" Maximum="100"
                                     Height="16" CornerRadius="4"
                                     Foreground="#4CAF50" />
                    </StackPanel>

                    <StackPanel Spacing="12" IsEnabled="{Binding AmplitudeTriggerEnabled}">
                        <StackPanel Spacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Threshold" Classes="DataLabel" />
                                <TextBlock Grid.Column="1" Text="{Binding AmplitudeThreshold, StringFormat={}{0} dB}"
                                           Classes="DataLabel" />
                            </Grid>
                            <Slider Value="{Binding AmplitudeThreshold}"
                                    Minimum="-60" Maximum="-10"
                                    TickFrequency="5" IsSnapToTickEnabled="True" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,12,*">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Pre-trigger (sec)" Classes="DataLabel" />
                                <NumericUpDown Value="{Binding PreTriggerSeconds}"
                                               Minimum="0" Maximum="10"
                                               Increment="1" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Post-trigger (sec)" Classes="DataLabel" />
                                <NumericUpDown Value="{Binding PostTriggerSeconds}"
                                               Minimum="1" Maximum="30"
                                               Increment="1" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Power Management -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="12">
                    <TextBlock Text="Power Management" Classes="SectionHeader" />

                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Low Battery Threshold" Classes="DataLabel" />
                            <TextBlock Grid.Column="1" Text="{Binding LowBatteryThreshold, StringFormat={}{0}%}"
                                       Classes="DataLabel" />
                        </Grid>
                        <Slider Value="{Binding LowBatteryThreshold}"
                                Minimum="5" Maximum="30"
                                TickFrequency="5" IsSnapToTickEnabled="True" />
                    </StackPanel>

                    <CheckBox IsChecked="{Binding AutoStopOnLowBattery}"
                              Content="Auto-stop recording on low battery"
                              Foreground="White" />
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Classes="ToolbarButton"
                        Command="{Binding ResetToDefaultsCommand}">
                    <TextBlock Text="Reset Defaults" HorizontalAlignment="Center" />
                </Button>
                <Button Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        Classes="PrimaryButton"
                        Command="{Binding SaveConfigCommand}"
                        IsEnabled="{Binding HasChanges}">
                    <TextBlock Text="Save Config" HorizontalAlignment="Center" />
                </Button>
            </Grid>

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}"
                       HorizontalAlignment="Center"
                       Classes="DataLabel"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <!-- Load Button -->
            <Button HorizontalAlignment="Stretch"
                    Classes="SecondaryButton"
                    Command="{Binding LoadConfigCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                    <PathIcon Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z"
                              Width="16" Height="16" />
                    <TextBlock Text="Load from Device" />
                </StackPanel>
            </Button>

        </StackPanel>
    </ScrollViewer>
</UserControl>
