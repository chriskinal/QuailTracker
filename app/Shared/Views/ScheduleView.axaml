<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuailTracker.Shared.ViewModels"
             x:Class="QuailTracker.Shared.Views.ScheduleView"
             x:DataType="vm:ScheduleViewModel">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="16">

            <!-- Sunrise Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Sunrise" Classes="SectionHeader" />
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding SunriseEnabled}"
                                      OnContent="On" OffContent="Off" />
                    </Grid>
                    <Grid ColumnDefinitions="*,12,*"
                          IsEnabled="{Binding SunriseEnabled}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Before (min)" Classes="DataLabel" />
                            <NumericUpDown Value="{Binding SunriseBefore}"
                                           Minimum="0" Maximum="180"
                                           Increment="5" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="After (min)" Classes="DataLabel" />
                            <NumericUpDown Value="{Binding SunriseAfter}"
                                           Minimum="0" Maximum="180"
                                           Increment="5" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Sunset Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Sunset" Classes="SectionHeader" />
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding SunsetEnabled}"
                                      OnContent="On" OffContent="Off" />
                    </Grid>
                    <Grid ColumnDefinitions="*,12,*"
                          IsEnabled="{Binding SunsetEnabled}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Before (min)" Classes="DataLabel" />
                            <NumericUpDown Value="{Binding SunsetBefore}"
                                           Minimum="0" Maximum="180"
                                           Increment="5" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="After (min)" Classes="DataLabel" />
                            <NumericUpDown Value="{Binding SunsetAfter}"
                                           Minimum="0" Maximum="180"
                                           Increment="5" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Freeform Windows Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="12">
                    <TextBlock Text="Recording Windows" Classes="SectionHeader" />

                    <!-- Preset Buttons -->
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Dawn/Dusk" Classes="SecondaryButton"
                                Command="{Binding PresetDawnDuskCommand}"
                                Margin="0,0,8,4" Padding="12,6" />
                        <Button Content="Dawn Only" Classes="SecondaryButton"
                                Command="{Binding PresetDawnOnlyCommand}"
                                Margin="0,0,8,4" Padding="12,6" />
                        <Button Content="Nocturnal" Classes="SecondaryButton"
                                Command="{Binding PresetNocturnalCommand}"
                                Margin="0,0,8,4" Padding="12,6" />
                        <Button Content="All Day" Classes="SecondaryButton"
                                Command="{Binding PresetAllDayCommand}"
                                Margin="0,0,8,4" Padding="12,6" />
                    </WrapPanel>

                    <!-- Window List -->
                    <ItemsControl ItemsSource="{Binding Windows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TimeWindowItem">
                                <Grid ColumnDefinitions="*,12,*,8,Auto" Margin="0,4">
                                    <TimePicker SelectedTime="{Binding StartTime}" />
                                    <TextBlock Grid.Column="1" Text="-"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                    <TimePicker Grid.Column="2" SelectedTime="{Binding EndTime}" />
                                    <Button Grid.Column="4" Content="X"
                                            Padding="8,4"
                                            Command="{Binding $parent[ItemsControl].((vm:ScheduleViewModel)DataContext).RemoveWindowCommand}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="+ Add Window"
                            Classes="SecondaryButton"
                            HorizontalAlignment="Left"
                            Command="{Binding AddWindowCommand}" />
                </StackPanel>
            </Border>

            <!-- Save/Load Buttons -->
            <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Classes="SecondaryButton"
                        Command="{Binding LoadScheduleCommand}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <PathIcon Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z"
                                  Width="16" Height="16" />
                        <TextBlock Text="Load" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        Classes="PrimaryButton"
                        Command="{Binding SaveScheduleCommand}"
                        IsEnabled="{Binding HasChanges}">
                    <TextBlock Text="Save Schedule" HorizontalAlignment="Center" />
                </Button>
            </Grid>

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}"
                       HorizontalAlignment="Center"
                       Classes="DataLabel"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />


        </StackPanel>
    </ScrollViewer>
</UserControl>
