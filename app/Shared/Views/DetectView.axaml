<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QuailTracker.Shared.ViewModels"
        x:Class="QuailTracker.Shared.Views.DetectView"
        x:DataType="vm:DetectViewModel">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="12">

            <!-- Model Status -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <TextBlock Text="Model Status" Classes="SectionHeader" />
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding ModelInfo}" FontSize="14" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding ModelColor}" />
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="{Binding DetectionStatus}"
                                           FontSize="12" Opacity="0.7" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Reload"
                                Command="{Binding ReloadModelCommand}"
                                Classes="SecondaryButton" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Detection Control -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="12">
                    <TextBlock Text="Detection Control" Classes="SectionHeader" />

                    <!-- Mission Mode -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Mission Mode" FontSize="12" Opacity="0.7" />
                        <ComboBox ItemsSource="{Binding MissionOptions}"
                                  SelectedIndex="{Binding SelectedMissionIndex}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Confidence Threshold -->
                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Confidence Threshold" FontSize="12" Opacity="0.7" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DetectionThreshold, StringFormat='{}{0}%'}"
                                       FontSize="12" FontWeight="SemiBold" />
                        </Grid>
                        <Slider Minimum="10" Maximum="100"
                                Value="{Binding DetectionThreshold}"
                                TickFrequency="5" IsSnapToTickEnabled="True" />
                    </StackPanel>

                    <!-- Window Step -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Window Step" FontSize="12" Opacity="0.7" />
                        <ComboBox ItemsSource="{Binding WindowStepOptions}"
                                  SelectedIndex="{Binding SelectedWindowStepIndex}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Save Button -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="12" Opacity="0.7"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="Save"
                                Command="{Binding SaveCommand}"
                                IsEnabled="{Binding HasChanges}"
                                Classes="PrimaryButton" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Detections: Stats + Last + Live Stream -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="8">
                    <!-- Line 1: Windows + Hits + Live toggle -->
                    <Grid ColumnDefinitions="Auto,6,Auto,*,Auto,6,Auto,*,Auto">
                        <TextBlock Text="Windows" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding WindowsProcessed}"
                                   FontSize="13" FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="4" Text="Hits" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="6" Text="{Binding DetectionHits}"
                                   FontSize="13" FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center" />
                        <ToggleSwitch Grid.Column="8"
                                      IsChecked="{Binding StreamEnabled}"
                                      OnContent="Live" OffContent="Live"
                                      Padding="0" Margin="0" />
                    </Grid>

                    <!-- Line 2: Last detection — species + time + confidence -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding LastSpecies}"
                                       FontSize="15" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="{Binding LastTime}"
                                       FontSize="11" Foreground="White" Opacity="0.5" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastConfidence}"
                                   FontSize="22" FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Live detection log -->
                    <ItemsControl ItemsSource="{Binding DetectionLog}"
                                  IsVisible="{Binding StreamEnabled}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11"
                                           FontFamily="Cascadia Mono, Consolas, monospace"
                                           Foreground="White" Opacity="0.8"
                                           Margin="0,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>


        </StackPanel>
    </ScrollViewer>

</UserControl>
