<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuailTracker.Shared.ViewModels"
             x:Class="QuailTracker.Shared.Views.ScheduleView"
             x:DataType="vm:ScheduleViewModel">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="16">

            <!-- Schedule Mode Card -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="12">
                    <TextBlock Text="Schedule Mode" Classes="SectionHeader" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="Mode" Classes="DataLabel" />
                        <ComboBox ItemsSource="{Binding ScheduleModeOptions}"
                                  SelectedIndex="{Binding SelectedScheduleModeIndex}"
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Sunrise/Sunset Card -->
            <Border Classes="CardPanel"
                    IsVisible="{Binding SelectedScheduleModeIndex, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=1}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Sunrise/Sunset Offsets" Classes="SectionHeader" />
                    <Grid ColumnDefinitions="*,12,*">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Before Sunrise (min)" Classes="DataLabel" />
                            <NumericUpDown Value="{Binding SunriseOffset}"
                                           Minimum="-120" Maximum="0"
                                           Increment="5" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="After Sunset (min)" Classes="DataLabel" />
                            <NumericUpDown Value="{Binding SunsetOffset}"
                                           Minimum="0" Maximum="120"
                                           Increment="5" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Manual Time Card -->
            <Border Classes="CardPanel"
                    IsVisible="{Binding SelectedScheduleModeIndex, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Manual Times" Classes="SectionHeader" />
                    <Grid ColumnDefinitions="*,12,*">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Start Time" Classes="DataLabel" />
                            <TimePicker SelectedTime="{Binding ManualStartTime}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="End Time" Classes="DataLabel" />
                            <TimePicker SelectedTime="{Binding ManualEndTime}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Classes="SecondaryButton"
                        Command="{Binding LoadScheduleCommand}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <PathIcon Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z"
                                  Width="16" Height="16" />
                        <TextBlock Text="Load" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        Classes="PrimaryButton"
                        Command="{Binding SaveScheduleCommand}"
                        IsEnabled="{Binding HasChanges}">
                    <TextBlock Text="Save Schedule" HorizontalAlignment="Center" />
                </Button>
            </Grid>

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}"
                       HorizontalAlignment="Center"
                       Classes="DataLabel"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
