<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QuailTracker.Shared.ViewModels"
             x:Class="QuailTracker.Shared.Views.HealthView"
             x:DataType="vm:HealthViewModel">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="12">

            <!-- Device / Battery / SD / Environment / BLE -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="5">
                    <!-- Line 1: Station ID + Firmware -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="{Binding StationId}" FontSize="16" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding FirmwareVersion}"
                                   FontSize="12" Foreground="White" Opacity="0.6"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Line 2: Battery bar + pct + voltage -->
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <TextBlock Text="Bat" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" Width="28" />
                        <ProgressBar Grid.Column="1" Value="{Binding BatteryPercentage}" Maximum="100"
                                     Height="6" CornerRadius="3"
                                     Foreground="{Binding BatteryColor}"
                                     VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding BatteryPercentage, StringFormat={}{0}%}"
                                   Margin="8,0,0,0" FontSize="13" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="{Binding BatteryVoltage}"
                                   Margin="6,0,0,0" FontSize="11" Foreground="White"
                                   Opacity="0.5" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Line 3: SD bar + pct + free -->
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <TextBlock Text="SD" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" Width="28" />
                        <ProgressBar Grid.Column="1" Value="{Binding SdFreePercent}" Maximum="100"
                                     Height="6" CornerRadius="3"
                                     Foreground="{Binding SdColor}"
                                     VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding SdFreePercent, StringFormat={}{0}%}"
                                   Margin="8,0,0,0" FontSize="13" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="{Binding SdFree}"
                                   Margin="6,0,0,0" FontSize="11" Foreground="White"
                                   Opacity="0.5" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Line 4: Temp + Humidity -->
                    <Grid ColumnDefinitions="Auto,6,Auto,*,Auto,6,Auto">
                        <TextBlock Text="Temp" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding Temperature}"
                                   FontSize="13" FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="4" Text="Hum" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="6" Text="{Binding Humidity}"
                                   FontSize="13" FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Line 5: BLE status + address -->
                    <Grid ColumnDefinitions="Auto,6,Auto,*,Auto">
                        <TextBlock Text="BLE" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding BleStatus}"
                                   FontSize="13" FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="4" Text="{Binding BleAddress}"
                                   FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- GPS -->
            <Border Classes="CardPanel">
                <StackPanel Spacing="5">
                    <!-- Line 1: GPS label + Fix status + Sats + PPS status + count + age -->
                    <Grid ColumnDefinitions="Auto,6,Auto,6,Auto,*,Auto,6,Auto,6,Auto,6,Auto">
                        <TextBlock Text="GPS" FontSize="13" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                        <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                                Background="{Binding GpsColor}">
                            <TextBlock Text="{Binding GpsStatus}" Foreground="White" FontSize="11" />
                        </Border>
                        <TextBlock Grid.Column="4" Text="{Binding GpsSatellites}"
                                   FontSize="13" FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="6" Text="PPS" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="8" Text="{Binding PpsStatus}"
                                   FontSize="12" FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="10" Text="{Binding PpsCount}"
                                   FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="12" Text="{Binding PpsAge}"
                                   FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Line 2: Position + Time -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding GpsPosition}" FontSize="12" Foreground="White"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding GpsTime}"
                                   FontSize="12" Foreground="White" Opacity="0.6"
                                   VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Since Last Visit -->
            <Border Classes="CardPanel" IsVisible="{Binding HasHealthReport}">
                <StackPanel Spacing="4">
                    <Grid ColumnDefinitions="Auto,8,Auto,*">
                        <TextBlock Text="Since Last Visit" FontSize="13" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center" />
                        <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                                Background="{Binding HealthOverallColor}">
                            <TextBlock Text="{Binding HealthOverallText}" Foreground="White" FontSize="11" />
                        </Border>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,8,*">
                        <TextBlock Text="Rec" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding HealthRec}"
                                   FontSize="12" Foreground="{Binding HealthRecColor}" VerticalAlignment="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,8,*">
                        <TextBlock Text="Det" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding HealthDet}"
                                   FontSize="12" Foreground="White" VerticalAlignment="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,8,*">
                        <TextBlock Text="Bat" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding HealthBat}"
                                   FontSize="12" Foreground="{Binding HealthBatColor}" VerticalAlignment="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,8,*">
                        <TextBlock Text="Sys" FontSize="11" Foreground="White" Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding HealthSys}"
                                   FontSize="12" Foreground="{Binding HealthSysColor}" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
