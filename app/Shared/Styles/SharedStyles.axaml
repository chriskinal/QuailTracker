<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- QuailTracker Mobile App Shared Styles -->

    <!-- Card Panel Style (dark, for content areas) -->
    <Style Selector="Border.CardPanel">
        <Setter Property="Background" Value="#DD2C3E50"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="BoxShadow" Value="0 2 8 0 #40000000"/>
    </Style>

    <!-- Dark Card Panel Style -->
    <Style Selector="Border.DarkCardPanel">
        <Setter Property="Background" Value="#DD1E2930"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="BoxShadow" Value="0 2 8 0 #40000000"/>
    </Style>

    <!-- Modern Primary Button Style (QuailTracker green) -->
    <Style Selector="Button.PrimaryButton">
        <Setter Property="Background" Value="#2E7D32"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.PrimaryButton:pointerover">
        <Setter Property="Background" Value="#388E3C"/>
    </Style>
    <Style Selector="Button.PrimaryButton:pressed">
        <Setter Property="Background" Value="#1B5E20"/>
    </Style>

    <!-- Modern Secondary Button Style (blue) -->
    <Style Selector="Button.SecondaryButton">
        <Setter Property="Background" Value="#3498DB"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.SecondaryButton:pointerover">
        <Setter Property="Background" Value="#2980B9"/>
    </Style>
    <Style Selector="Button.SecondaryButton:pressed">
        <Setter Property="Background" Value="#21618C"/>
    </Style>

    <!-- Toolbar Button Style -->
    <Style Selector="Button.ToolbarButton">
        <Setter Property="Background" Value="#DD34495E"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.ToolbarButton:pointerover">
        <Setter Property="Background" Value="#DD475A6E"/>
    </Style>
    <Style Selector="Button.ToolbarButton:pressed">
        <Setter Property="Background" Value="#DD3E5872"/>
    </Style>

    <!-- Danger Button Style (red) -->
    <Style Selector="Button.DangerButton">
        <Setter Property="Background" Value="#E53935"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.DangerButton:pointerover">
        <Setter Property="Background" Value="#F44336"/>
    </Style>
    <Style Selector="Button.DangerButton:pressed">
        <Setter Property="Background" Value="#C62828"/>
    </Style>

    <!-- Section Header Style -->
    <Style Selector="TextBlock.SectionHeader">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#AAAAAA"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- Data Label Style -->
    <Style Selector="TextBlock.DataLabel">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#888888"/>
    </Style>

    <!-- Data Value Style -->
    <Style Selector="TextBlock.DataValue">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Large Value Style -->
    <Style Selector="TextBlock.LargeValue">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- Status Bar Style -->
    <Style Selector="Border.StatusBar">
        <Setter Property="Background" Value="#DD1E2930"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="BorderBrush" Value="#DD475A6E"/>
    </Style>

</Styles>
